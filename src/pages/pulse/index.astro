        ${peComment ? p(peComment) : ''}
        ${betaComment ? p(betaComment) : ''}
        ${kvGrid([
          ['Revenue Growth',   fmtPct(revGrowth),   'YoY'],
          ['Earnings Growth',  fmtPct(earnGrowth),  'YoY'],
