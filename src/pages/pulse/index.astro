    // 3. EMA signal analysis
    html += card('EMA Signal Analysis — 8/21 Crossover', `
      <div style="display:inline-flex;align-items:center;gap:8px;padding:6px 14px;border-radius:4px;background:${maState.fastAboveSlow?'rgba(200,241,53,0.08)':'rgba(240,96,76,0.08)'};border:1px solid ${maState.fastAboveSlow?'rgba(200,241,53,0.25)':'rgba(240,96,76,0.25)'};margin-bottom:16px">
