    setTimeout(() => { newWin.focus(); newWin.print(); URL.revokeObjectURL(url); }, 700);
  });

  async function analyseStock(ticker) {
    currentTicker = ticker;
    document.getElementById('btn-label').style.display   = 'none';
    document.getElementById('btn-spinner').style.display = 'inline-block';
    const errEl = document.getElementById('error-msg');
    errEl.style.display = 'none'; errEl.textContent = '';
    ['analysis-section','news-section','stats-section'].forEach(id => document.getElementById(id).style.display = 'none');
    document.getElementById('score-strip').style.display = 'none';
    try {
      const [chartResult, summary, news] = await Promise.all([fetchChartData(ticker), fetchSummary(ticker), fetchNews(ticker)]);
      chartData = prepareChartData(chartResult);
      createChart(chartData);
      const result = computePulseScore(chartResult, summary);
      updateUI(ticker, result, summary);
      renderNews(news, ticker);
    } catch (err) {
      console.error(err);
      errEl.textContent = `⚠ Could not fetch data for "${ticker}". Check the ticker is a valid US stock symbol. (${err.message})`;
      errEl.style.display = 'block';
    } finally {
      document.getElementById('btn-label').style.display   = 'inline';
      document.getElementById('btn-spinner').style.display = 'none';
    }
  }

  document.getElementById('search-form').addEventListener('submit', e => {
    e.preventDefault();
    const t = document.getElementById('ticker-input').value.trim().toUpperCase();
    if (t) analyseStock(t);
  });

  </script>
</Base>
