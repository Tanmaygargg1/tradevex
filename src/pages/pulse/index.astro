    // 5. Analyst coverage
    if (targetMean && numAnalysts) {
      const upside = rd.price ? (targetMean - rd.price) / rd.price * 100 : null;
      html += card('Analyst Coverage', `
        ${kvGrid([
          ['Consensus Target',  '$'+fmt(targetMean),  recKey ? recKey.toUpperCase() : ''],
