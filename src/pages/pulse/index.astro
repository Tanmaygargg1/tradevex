      ${p(maVerdict)}
      ${p('The 8/21 EMA crossover was chosen for Pulse because exponential moving averages weight recent price data more heavily than their simple counterparts, making them faster to react to trend changes. The 8-period fast EMA and 21-period slow EMA are a Fibonacci-derived pair — the ratio between them creates a natural sensitivity balance that filters out much of the noise a shorter combination would generate, while remaining responsive enough to catch moves early. When the fast EMA crosses above the slow, the strategy enters bullish mode. When it crosses below, it switches to bearish.')}
    `);

    // 4. Fundamentals
    const hasFundamentals = marketCap || trailingPE || beta || profitMargin || revGrowth;
    if (hasFundamentals) {
      html += card('Fundamental Snapshot', `
        ${kvGrid([
          ['Market Cap',    fmtM(marketCap),    ''],
          ['Trailing P/E',  trailingPE!=null?fmt(trailingPE,1)+'×':'N/A', ''],
