  function updateUI(ticker, result, summary) {
    const interp = interpretation(Math.round(result.total));
    const total  = Math.round(result.total);
    const strip = document.getElementById('score-strip');
    strip.style.display = 'flex';
    const st = document.getElementById('strip-total');
    st.textContent = total; st.className = `${interp.cls}`; st.style.cssText = 'font-family:var(--font-head);font-size:1.8rem;font-weight:800;line-height:1';
    const sb2 = document.getElementById('strip-badge');
    sb2.textContent = interp.label; sb2.className = `signal-badge ${interp.badge}`;
    result.factors.forEach((f,i) => {
      const el = document.getElementById(`strip-f${i+1}`);
      el.textContent = `${f.score}/20`; el.className = pillCls(f.score);
    });
    document.getElementById('ticker-heading').style.display = 'flex';
    document.getElementById('ticker-name').textContent = ticker;
    document.getElementById('company-name').textContent = summary?.assetProfile?.longName ?? '';
    const sb = document.getElementById('signal-badge');
    sb.textContent = interp.label; sb.className = `signal-badge ${interp.badge}`;
    document.getElementById('stats-section').style.display = 'block';
    const cc = result.stats.changePct >= 0 ? 'var(--accent)' : 'var(--danger)';
    document.getElementById('stat-price').textContent  = `$${fmt(result.stats.price)}`;
    document.getElementById('stat-change').innerHTML   = `<span style="color:${cc}">${pct(result.stats.changePct,2)}</span>`;
    document.getElementById('stat-vol').textContent    = `${fmt(result.stats.surge,2)}× avg`;
    document.getElementById('stat-sma').textContent    = pct(result.stats.pctAbove,2);
    const lo52 = result.stats.lo52, hi52 = result.stats.hi52;
    document.getElementById('stat-52w').textContent    = lo52&&hi52 ? `$${fmt(lo52)} — $${fmt(hi52)}` : '—';
    renderRawData(result.rawData);
    renderFactorSteps(result.factors);
    document.getElementById('analysis-section').style.display = 'block';
    result.factors.forEach((f,i) => {
      document.getElementById(`bar-f${i+1}`).style.width = `${(f.score/20)*100}%`;
      document.getElementById(`val-f${i+1}`).textContent = `${f.score}/20`;
    });
    const bs = document.getElementById('big-score');
    bs.textContent = total; bs.className = `score-display__num ${interp.cls}`;
    const scoreBadge = document.getElementById('score-badge');
    scoreBadge.textContent = interp.label; scoreBadge.className = `signal-badge ${interp.badge}`;
    document.getElementById('score-interp').textContent = interp.text;
    renderInlineReport(result, summary);
  }

  document.getElementById('download-report-btn').addEventListener('click', () => {
