        ${growthComment ? p(growthComment) : ''}
        ${marginComment ? p(marginComment) : ''}
        ${(totalCash || totalDebt || freeCF || currentRatio) ? `
          ${kvGrid([
            ['Total Cash',     fmtM(totalCash),  ''],
            ['Total Debt',     fmtM(totalDebt),  ''],
            ['Free Cash Flow', fmtM(freeCF),     'TTM'],
            ['Current Ratio',  currentRatio!=null?fmt(currentRatio,2):'N/A', 'liquidity'],
